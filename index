  {id:uid(),title:'Enviar acuerdos a equipo',desc:'Resumen breve con tareas derivadas y fechas.',project:p[1].id,status:'terminada',priority:'baja',owner:'Fabián',due:isoAdd(-1),type:'correo'}
 ];
 state.meetings=[
