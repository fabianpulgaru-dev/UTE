function projectMeetingList(items){return items.length?items.map(m=>`<div class="meeting"><div class="meeting-head"><div><div class="meeting-title">${esc(m.title)}</div><div class="meeting-meta">${fmt(m.date)} · ${esc(m.people)}</div></div><button class="btn btn-ghost btn-sm" onclick="deleteMeeting('${m.id}')">✕</button></div><p><b>Temas:</b> ${esc(m.topics||'')}</p><p><b>Acuerdos:</b> ${esc(m.agreements||'')}</p></div>`).join(''):'<div class="proj-empty">No hay reuniones en este proyecto.</div>'}
function projectNoteList(items){return items.length?items.map(n=>`<div class="note"><div class="note-head"><div class="note-kind">${esc(n.kind)}</div><div class="note-date">${new Date(n.date).toLocaleString('es-CL')}</div></div><p>${esc(n.text)}</p><div style="margin-top:8px"><button class="btn btn-ghost btn-sm" onclick="deleteNote('${n.id}')">Eliminar</button></div></div>`).join(''):'<div class="proj-empty">No hay notas en este proyecto.</div>'}
function projectNextSteps(p,tasks,cases,meetings){
 const high=tasks.filter(t=>t.priority==='alta').slice(0,3);
 const blocked=tasks.filter(t=>t.status==='bloqueada').slice(0,3);
 const caseNext=cases.filter(c=>c.status!=='cerrado').slice(0,3);
 return `<div class="proj-next-box"><h4>1. Cerrar urgencias</h4><p>${high.length?high.map(t=>`• ${esc(t.title)} — ${fmt(t.due)}`).join('<br>'):'No hay tareas de alta prioridad abiertas.'}</p></div>
 <div class="proj-next-box"><h4>2. Desbloquear pendientes</h4><p>${blocked.length?blocked.map(t=>`• ${esc(t.title)} — ${esc(t.desc||'sin detalle')}`).join('<br>'):'No hay bloqueos registrados.'}</p></div>
 <div class="proj-next-box"><h4>3. Seguir casos específicos</h4><p>${caseNext.length?caseNext.map(c=>`• ${esc(c.name)} — ${esc(c.next||'sin próxima acción')}`).join('<br>'):'No hay casos abiertos vinculados.'}</p></div>
 <div class="proj-next-box"><h4>4. Preparar próxima reunión</h4><p>${meetings.filter(m=>m.date>=isoAdd(0)).length?meetings.filter(m=>m.date>=isoAdd(0)).slice(0,2).map(m=>`• ${fmt(m.date)} · ${esc(m.title)} — ${esc(m.topics||'sin temas')}`).join('<br>'):'No hay reuniones próximas registradas.'}</p></div>`;
}

function tagClass(v){return v==='alta'?'tag-clay':v==='media'?'tag-gold':'tag-olive'}
function setProjectFilter(f,el){projectFilter=f;el.parentElement.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));el.classList.add('active');renderProjects()}
function setTaskFilter(f,el){taskFilter=f;el.parentElement.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));el.classList.add('active');renderTasks()}
function renderTasks(){
 let arr=searchFilter(state.tasks,['title','desc','owner','type','status','priority']);
 if(taskFilter!=='todas')arr=arr.filter(t=>['pendiente','en proceso','bloqueada','terminada'].includes(taskFilter)?t.status===taskFilter:t.priority===taskFilter);
 arr.sort((a,b)=>(a.status==='terminada')-(b.status==='terminada')||(a.due||'').localeCompare(b.due||''));
 $('taskList').innerHTML=arr.length?arr.map(t=>`<div class="task ${t.priority}"><div class="check ${t.status==='terminada'?'done':''}" onclick="toggleTask('${t.id}')"></div><div class="task-body"><div class="task-title ${t.status==='terminada'?'done':''}">${esc(t.title)}</div><div class="task-desc">${esc(t.desc||'')}</div><div class="task-meta"><span class="tag tag-blue">${esc(projName(t.project))}</span><span class="tag ${tagClass(t.priority)}">${t.priority}</span><span class="tag tag-olive">${t.status}</span><span class="tag tag-gold">${fmt(t.due)}</span><span class="tag tag-rose">${esc(t.owner)}</span></div></div><div class="task-actions"><button class="btn btn-ghost btn-sm" onclick="deleteTask('${t.id}')">✕</button></div></div>`).join(''):`<div class="empty"><div class="ico">✅</div><p>No hay tareas para este filtro.</p></div>`;
}
function renderWeek(){
 const names=['Lunes','Martes','Miércoles','Jueves','Viernes']; const monday=new Date(today); const day=today.getDay()||7; monday.setDate(today.getDate()-day+1);
 $('weekGrid').innerHTML=names.map((name,i)=>{const d=new Date(monday);d.setDate(monday.getDate()+i);const iso=d.toISOString().slice(0,10);const tasks=state.tasks.filter(t=>t.due===iso);const meets=state.meetings.filter(m=>m.date===iso);return `<div class="daycol"><div class="dayhd"><div class="dayname">${name}</div><div class="daydate">${fmt(iso)}</div></div><div class="daybody">${meets.map(m=>`<div class="daytask"><b>📝 ${esc(m.title)}</b><p>${esc(m.people)}</p></div>`).join('')}${tasks.map(t=>`<div class="daytask"><b>${t.status==='terminada'?'✓':'•'} ${esc(t.title)}</b><p>${esc(projName(t.project))} · ${t.priority}</p></div>`).join('')||(!meets.length?'<div class="empty" style="padding:20px 5px"><p>Sin pendientes</p></div>':'')}</div></div>`}).join('');
}
