 ];
 state.cases=[
  {id:uid(),name:'Estudiante con baja participación',type:'Estudiante',program:'Trayectoria / PACE',project:p[2].id,status:'abierto',alert:'alta',owner:'Fabián',next:'Contactar y definir apoyo académico inicial.',due:isoAdd(1),desc:'Caso requiere seguimiento por baja participación y riesgo de desvinculación.',history:'Registro inicial creado desde monitoreo semanal.'},
  {id:uid(),name:'Docente requiere orientación inclusiva',type:'Docente',program:'Docencia inclusiva',project:p[1].id,status:'en seguimiento',alert:'media',owner:'Fabián + Sol',next:'Enviar propuesta de ajustes razonables y recursos DUA.',due:isoAdd(3),desc:'Solicitud asociada a barreras de participación en aula.',history:'Conversación inicial realizada; falta formalizar apoyos.'},
  {id:uid(),name:'Carrera con baja asistencia a talleres',type:'Carrera',program:'UTE',project:p[2].id,status:'abierto',alert:'media',owner:'Fabián',next:'Revisar datos y preparar estrategia de convocatoria.',due:isoAdd(4),desc:'Caso de seguimiento por baja vinculación con actividades de fortalecimiento.',history:'Detectado en revisión de participación.'}
 ];
 state.notes=[
  {id:uid(),kind:'decisión',text:'La plataforma debe separar seguimiento operativo, reportes y trabajo reflexivo. No solo checklist.',project:p[2].id,date:new Date().toISOString()},
  {id:uid(),kind:'idea',text:'Crear una vista de “temas para jefatura” que se alimente de tareas bloqueadas y acuerdos recientes.',project:p[2].id,date:new Date().toISOString()}
 ]; save();
}
let taskFilter='todas', projectFilter='todos', caseFilter='todos', currentProjectId=null, currentProjectTab='resumen', modalContext={type:null,ctx:''};
if(!state.cases.length && state.projects?.length){ const p=state.projects; state.cases=[{id:uid(),name:'Caso específico de prueba',type:'Estudiante / docente / carrera',program:'UTE',project:p[0]?.id||'',status:'abierto',alert:'media',owner:'Fabián',next:'Registrar la próxima acción del caso.',due:isoAdd(2),desc:'Usa esta ficha para hacer seguimiento de una situación puntual.',history:'Caso creado como ejemplo inicial.'}]; save(); }
function uid(){return Math.random().toString(36).slice(2)+Date.now().toString(36)}
function save(){localStorage.setItem('mesaTrabajoV1',JSON.stringify(state))}
function isoAdd(n){const d=new Date();d.setDate(d.getDate()+n);return d.toISOString().slice(0,10)}

function ensureStateShape(){
 state.projects=Array.isArray(state.projects)?state.projects:[];
 state.tasks=Array.isArray(state.tasks)?state.tasks:[];
 state.meetings=Array.isArray(state.meetings)?state.meetings:[];
 state.cases=Array.isArray(state.cases)?state.cases:[];
 state.notes=Array.isArray(state.notes)?state.notes:[];
 state.users=Array.isArray(state.users)?state.users:[];
}
function val(id, fallback=''){const el=$(id);return el?String(el.value||'').trim():fallback}
function numVal(id, fallback=0){const n=Number(val(id,fallback));return Number.isFinite(n)?n:fallback}
function bindModalButtons(){
 const m=$('modal');
 m.querySelectorAll('[data-close-modal]').forEach(b=>b.onclick=closeModal);
 m.querySelectorAll('[data-save-modal]').forEach(b=>b.onclick=handleModalSave);
}
function handleModalSave(){
 try{
   const t=modalContext.type;
   if(t==='project')return saveProject();
   if(t==='task')return saveTask();
   if(t==='meeting')return saveMeeting();
   if(t==='note')return saveNote();
   if(t==='case')return saveCase();
   if(t==='caseTask')return saveCaseTask(modalContext.ctx);
   if(t==='user')return saveUser();
 }catch(err){
   console.error(err);
   toast('No se pudo guardar: '+(err?.message||'revisa los campos'));
 }
}

function fmt(d){if(!d)return 'Sin fecha';return new Date(d+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short'})}
function projName(id){return state.projects.find(p=>p.id===id)?.name||'Sin proyecto'}
function navTo(sec){document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));$('sec-'+sec).classList.add('active');document.querySelectorAll('.navitem').forEach(n=>n.classList.remove('active'));[...document.querySelectorAll('.navitem')].find(n=>n.getAttribute('onclick')?.includes(sec))?.classList.add('active');renderAll()}
function searchFilter(arr,fields){const q=($('globalSearch').value||'').toLowerCase().trim();if(!q)return arr;return arr.filter(o=>fields.some(f=>String(o[f]||'').toLowerCase().includes(q)))}
function renderAll(){renderHeader();renderInicio();renderProjects();renderProjectDetail();renderTasks();renderWeek();renderCases();renderMeetings();renderNotes();renderAccess();}
function renderHeader(){
 $('todayDay').textContent=today.toLocaleDateString('es-CL',{day:'2-digit'});$('todayLabel').textContent=today.toLocaleDateString('es-CL',{weekday:'long',month:'long'});
 const pend=state.tasks.filter(t=>t.status!=='terminada');const done=state.tasks.filter(t=>t.status==='terminada').length;const pct=state.tasks.length?Math.round(done/state.tasks.length*100):0;
 $('pulseDone').textContent=pct+'%';$('pulseBar').style.width=pct+'%';$('pulseDate').textContent='Semana '+getWeekNumber(today);$('taskBadge').textContent=pend.length; $('taskBadge').style.display=pend.length?'inline':'none';
}
function getWeekNumber(d){const date=new Date(Date.UTC(d.getFullYear(),d.getMonth(),d.getDate()));const dayNum=date.getUTCDay()||7;date.setUTCDate(date.getUTCDate()+4-dayNum);const yearStart=new Date(Date.UTC(date.getUTCFullYear(),0,1));return Math.ceil((((date-yearStart)/86400000)+1)/7)}
function renderInicio(){
 const pend=state.tasks.filter(t=>t.status!=='terminada');$('sPend').textContent=pend.length;$('sUrg').textContent=pend.filter(t=>t.priority==='alta').length;$('sProj').textContent=state.projects.filter(p=>p.status==='activo').length;$('sCases').textContent=(state.cases||[]).filter(c=>c.status!=='cerrado').length;$('sMeet').textContent=state.meetings.filter(m=>m.date>=isoAdd(0)).length;
 mini('inicioUrgentes', pend.filter(t=>t.priority==='alta').sort((a,b)=>(a.due||'').localeCompare(b.due||'')).slice(0,5).map(t=>({dot:t.priority,title:t.title,meta:`${projName(t.project)} · ${fmt(t.due)} · ${t.owner}`})), 'No hay urgencias abiertas.');
 mini('inicioReuniones', state.meetings.filter(m=>m.date>=isoAdd(0)).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,4).map(m=>({dot:'media',title:m.title,meta:`${fmt(m.date)} · ${m.people}`})), 'No hay reuniones próximas.');
 mini('inicioProyectos', state.projects.filter(p=>p.status==='activo').slice(0,4).map(p=>({dot:p.priority,title:p.name,meta:`${p.progress}% · ${p.owner}`})), 'No hay proyectos activos.');
 mini('inicioNotas', state.notes.slice().sort((a,b)=>b.date.localeCompare(a.date)).slice(0,4).map(n=>({dot:'baja',title:n.kind.toUpperCase(),meta:n.text.slice(0,100)})), 'No hay notas todavía.');
}
function mini(id,items,empty){$(id).innerHTML=items.length?items.map(i=>`<div class="mini-item"><span class="dot ${i.dot}"></span><div><div class="mini-title">${esc(i.title)}</div><div class="mini-meta">${esc(i.meta)}</div></div></div>`).join(''):`<div class="empty"><div class="ico">✦</div><p>${empty}</p></div>`}
function renderProjects(){
 let arr=searchFilter(state.projects,['name','desc','owner','status']); if(projectFilter!=='todos')arr=arr.filter(p=>p.status===projectFilter);
 $('projectGrid').innerHTML=arr.length?arr.map(p=>{
   const tareas=state.tasks.filter(t=>t.project===p.id);
   const abiertas=tareas.filter(t=>t.status!=='terminada').length;
   const casos=(state.cases||[]).filter(c=>c.project===p.id && c.status!=='cerrado').length;
   const reuniones=state.meetings.filter(m=>m.project===p.id && m.date>=isoAdd(0)).length;
   return `<div class="project-card" onclick="openProject('${p.id}')">
     <div class="project-top"><div class="project-name">${esc(p.name)}</div><span class="tag ${tagClass(p.priority)}">${p.priority}</span></div>
     <p class="project-desc">${esc(p.desc)}</p>
     <div class="progress-line"><div style="width:${p.progress}%"></div></div>
     <div class="project-foot"><span>${p.status} · ${p.owner}</span><span>${p.progress}%</span></div>
     <div class="project-foot" style="margin-top:8px"><span>${abiertas} tareas abiertas · ${casos} casos · ${reuniones} reuniones</span><span>abrir →</span></div>
     <div style="display:flex;gap:6px;margin-top:12px" onclick="event.stopPropagation()">
       <button class="btn btn-outline btn-sm" onclick="openModal('task','${p.id}')">+ Tarea</button>
       <button class="btn btn-outline btn-sm" onclick="openProject('${p.id}')">Abrir</button>
       <button class="btn btn-ghost btn-sm" onclick="deleteProject('${p.id}')">Eliminar</button>
     </div>
   </div>`
 }).join(''):`<div class="empty"><div class="ico">📁</div><p>No hay proyectos con este filtro.</p></div>`;
}

function openProject(id){ensureStateShape();currentProjectId=id;currentProjectTab='resumen';$('projectListView').classList.add('off');$('projectDetailView').classList.add('on');renderProjectDetail();setTimeout(()=>{$('sec-proyectos')?.scrollIntoView({block:'start'});},0)}
function closeProjectDetail(){currentProjectId=null;$('projectDetailView').classList.remove('on');$('projectListView').classList.remove('off');renderProjects()}
function setProjectTab(tab,el){currentProjectTab=tab;document.querySelectorAll('.proj-tab').forEach(t=>t.classList.remove('active'));if(el)el.classList.add('active');renderProjectDetail()}
function renderProjectDetail(){
 const box=$('projectDetailView'); if(!box)return;
 if(!currentProjectId){box.innerHTML='';return}
 const p=state.projects.find(x=>x.id===currentProjectId); if(!p){closeProjectDetail();return}
 const tareas=state.tasks.filter(t=>t.project===p.id);
 const abiertas=tareas.filter(t=>t.status!=='terminada');
 const cerradas=tareas.filter(t=>t.status==='terminada');
 const reuniones=state.meetings.filter(m=>m.project===p.id).sort((a,b)=>(a.date||'').localeCompare(b.date||''));
 const casos=(state.cases||[]).filter(c=>c.project===p.id);
 const notas=state.notes.filter(n=>n.project===p.id).sort((a,b)=>b.date.localeCompare(a.date));
 const pct=tareas.length?Math.round(cerradas.length/tareas.length*100):p.progress||0;
 const tab=currentProjectTab;
 box.innerHTML=`<div class="proj-hero">
   <button class="proj-back" onclick="closeProjectDetail()">← Volver a proyectos</button>
   <h2>${esc(p.name)}</h2>
   <p>${esc(p.desc||'Sin descripción todavía.')}</p>
   <div class="proj-hero-meta">
     <span class="tag ${tagClass(p.priority)}">Prioridad ${esc(p.priority)}</span>
     <span class="tag tag-blue">${esc(p.status)}</span>
     <span class="tag tag-rose">${esc(p.owner)}</span>
     <span class="tag tag-gold">${pct}% de avance real</span>
   </div>
 </div>
 <div class="proj-tabs">
   ${projTabBtn('resumen','Resumen',tab)}
   ${projTabBtn('tareas','Tareas',tab)}
   ${projTabBtn('casos','Casos',tab)}
   ${projTabBtn('reuniones','Reuniones',tab)}
   ${projTabBtn('bitacora','Bitácora',tab)}
   ${projTabBtn('proximos','Próximos pasos',tab)}
 </div>
 <div class="proj-panel ${tab==='resumen'?'active':''}">
   <div class="proj-kpis">
     <div class="proj-kpi"><div class="n">${tareas.length}</div><div class="l">tareas</div></div>
     <div class="proj-kpi"><div class="n">${abiertas.length}</div><div class="l">abiertas</div></div>
     <div class="proj-kpi"><div class="n">${casos.filter(c=>c.status!=='cerrado').length}</div><div class="l">casos abiertos</div></div>
     <div class="proj-kpi"><div class="n">${reuniones.filter(m=>m.date>=isoAdd(0)).length}</div><div class="l">reuniones próximas</div></div>
   </div>
   <div class="proj-summary-grid">
     <div class="card"><div class="card-title">🔥 Pendientes principales</div>${projectMiniTasks(abiertas.slice().sort((a,b)=>(a.due||'').localeCompare(b.due||'')).slice(0,5))}</div>
     <div class="card"><div class="card-title">🎯 Casos vinculados</div>${projectMiniCases(casos.filter(c=>c.status!=='cerrado').slice(0,4))}</div>
     <div class="card"><div class="card-title">📝 Próximas reuniones</div>${projectMiniMeetings(reuniones.filter(m=>m.date>=isoAdd(0)).slice(0,4))}</div>
     <div class="card"><div class="card-title">📓 Últimas notas</div>${projectMiniNotes(notas.slice(0,4))}</div>
   </div>
 </div>
 <div class="proj-panel ${tab==='tareas'?'active':''}">
   <div style="display:flex;justify-content:flex-end;margin-bottom:10px"><button class="btn btn-primary btn-sm" onclick="openModal('task','${p.id}')">+ Tarea del proyecto</button></div>
   ${projectTaskList(tareas)}
 </div>
 <div class="proj-panel ${tab==='casos'?'active':''}">
   <div style="display:flex;justify-content:flex-end;margin-bottom:10px"><button class="btn btn-primary btn-sm" onclick="openModal('case','${p.id}')">+ Caso del proyecto</button></div>
   <div class="case-grid">${casos.length?casos.map(projectCaseCard).join(''):'<div class="proj-empty">No hay casos vinculados a este proyecto.</div>'}</div>
 </div>
 <div class="proj-panel ${tab==='reuniones'?'active':''}">
   <div style="display:flex;justify-content:flex-end;margin-bottom:10px"><button class="btn btn-primary btn-sm" onclick="openModal('meeting','${p.id}')">+ Reunión del proyecto</button></div>
   ${projectMeetingList(reuniones)}
 </div>
 <div class="proj-panel ${tab==='bitacora'?'active':''}">
   <div style="display:flex;justify-content:flex-end;margin-bottom:10px"><button class="btn btn-primary btn-sm" onclick="openModal('note','${p.id}')">+ Nota del proyecto</button></div>
   ${projectNoteList(notas)}
 </div>
 <div class="proj-panel ${tab==='proximos'?'active':''}">
   ${projectNextSteps(p,abiertas,casos,reuniones)}
 </div>`;
}
function projTabBtn(id,label,current){return `<button class="proj-tab ${current===id?'active':''}" onclick="setProjectTab('${id}',this)">${label}</button>`}
function projectMiniTasks(items){return items.length?items.map(t=>`<div class="mini-item"><span class="dot ${t.priority}"></span><div><div class="mini-title">${esc(t.title)}</div><div class="mini-meta">${esc(t.status)} · ${fmt(t.due)} · ${esc(t.owner)}</div></div></div>`).join(''):'<div class="proj-empty">No hay tareas pendientes.</div>'}
function projectMiniCases(items){return items.length?items.map(c=>`<div class="mini-item"><span class="dot ${c.alert}"></span><div><div class="mini-title">${esc(c.name)}</div><div class="mini-meta">alerta ${esc(c.alert)} · ${esc(c.status)}</div></div></div>`).join(''):'<div class="proj-empty">No hay casos abiertos.</div>'}
