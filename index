 save(); closeModal(); renderAll(); toast('Caso guardado');
}
function saveCaseTask(caseId){
 ensureStateShape();
 const c=(state.cases||[]).find(x=>x.id===caseId);
 const title=val('mTitle') || (c?'Seguimiento: '+c.name:'Tarea de seguimiento');
 state.tasks.push({id:uid(),title,desc:(val('mDesc')||'')+(c?'\n\nCaso asociado: '+c.name:''),project:val('mProject',c?.project||currentProjectId||state.projects[0]?.id||''),status:val('mStatus','pendiente'),priority:val('mPriority',c?.alert||'media'),owner:val('mOwner',c?.owner||'Fabián'),due:val('mDue'),type:'seguimiento'});
 if(c){c.history=(c.history||'')+'\n- '+new Date().toLocaleDateString('es-CL')+': se creó una tarea de seguimiento.'}
 save(); closeModal(); renderAll(); toast('Tarea derivada creada');
}
function closeCase(id){ensureStateShape();const c=state.cases.find(x=>x.id===id);if(!c)return;c.status=c.status==='cerrado'?'abierto':'cerrado';save();renderAll()}
function deleteCase(id){ensureStateShape();state.cases=state.cases.filter(x=>x.id!==id);save();renderAll()}
function saveUser(){
 ensureStateShape();
 const email=val('mEmail');
 if(!email){toast('Agrega un correo');return}
 state.users.push({id:uid(),name:val('mName','Usuario'),email,role:val('mRole','Solo lectura'),scope:val('mScope','Por definir')});
 save(); closeModal(); renderAll(); toast('Usuario agregado');
}
function toggleTask(id){const t=state.tasks.find(x=>x.id===id);t.status=t.status==='terminada'?'pendiente':'terminada';save();renderAll()}
function deleteTask(id){state.tasks=state.tasks.filter(x=>x.id!==id);save();renderAll()}
function deleteProject(id){if(confirm('¿Eliminar proyecto? Las tareas asociadas quedarán sin proyecto.')){state.projects=state.projects.filter(x=>x.id!==id);if(currentProjectId===id)currentProjectId=null;save();renderAll();if(!currentProjectId){$('projectDetailView')?.classList.remove('on');$('projectListView')?.classList.remove('off')}}}
function deleteMeeting(id){state.meetings=state.meetings.filter(x=>x.id!==id);save();renderAll()}
function deleteNote(id){state.notes=state.notes.filter(x=>x.id!==id);save();renderAll()}
function deleteUser(id){state.users=state.users.filter(x=>x.id!==id);save();renderAll()}
function seedWeek(){toast('La semana se actualiza según las fechas límite registradas')}
function generateReport(){
 const pend=state.tasks.filter(t=>t.status!=='terminada'); const done=state.tasks.filter(t=>t.status==='terminada'); const blocked=state.tasks.filter(t=>t.status==='bloqueada'); const urgent=pend.filter(t=>t.priority==='alta');
 const active=state.projects.filter(p=>p.status==='activo'); const openCases=(state.cases||[]).filter(c=>c.status!=='cerrado'); const highCases=openCases.filter(c=>c.alert==='alta'); const next=state.meetings.filter(m=>m.date>=isoAdd(0)).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,3);
 $('reportOut').textContent=`REPORTE SEMANAL · MESA DE TRABAJO\n\n1. Estado general\n- Proyectos activos: ${active.length}\n- Tareas pendientes: ${pend.length}\n- Tareas cerradas: ${done.length}\n- Tareas bloqueadas: ${blocked.length}\n- Casos abiertos: ${openCases.length}\n- Casos con alerta alta: ${highCases.length}\n\n2. Prioridades abiertas\n${urgent.length?urgent.map(t=>`- ${t.title} (${projName(t.project)}, ${fmt(t.due)}, ${t.owner})`).join('\n'):'- No hay tareas de alta prioridad abiertas.'}\n\n3. Proyectos activos\n${active.map(p=>`- ${p.name}: ${p.progress}% · ${p.owner}`).join('\n')}\n\n4. Casos específicos\n${openCases.length?openCases.slice(0,5).map(c=>`- ${c.name}: alerta ${c.alert} · ${c.status} · próxima acción: ${c.next||'sin definir'}`).join('\n'):'- No hay casos abiertos registrados.'}\n\n5. Próximas reuniones\n${next.length?next.map(m=>`- ${fmt(m.date)} · ${m.title} · ${m.people}`).join('\n'):'- No hay reuniones próximas registradas.'}\n\n6. Bloqueos\n${blocked.length?blocked.map(t=>`- ${t.title}: ${t.desc}`).join('\n'):'- Sin bloqueos registrados.'}\n\n7. Próximos pasos sugeridos\n- Cerrar tareas de alta prioridad con fecha próxima.\n- Revisar proyectos con avance menor al 50%.\n- Transformar acuerdos de reuniones en tareas concretas.`;
}
function copyReport(){navigator.clipboard.writeText($('reportOut').textContent);toast('Reporte copiado')}
function esc(s){return String(s||'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]))}
function toast(msg){const t=$('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200)}
renderAll();
</script>
</body>
</html>
