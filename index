function closeModal(){$('modalBg').classList.remove('on')}
function saveProject(){
 ensureStateShape();
 const name=val('mName');
 if(!name){toast('Ponle nombre al proyecto');return}
 const project={id:uid(),name,desc:val('mDesc'),status:val('mStatus','activo'),priority:val('mPriority','media'),owner:val('mOwner','Fabián'),progress:Math.max(0,Math.min(100,numVal('mProgress',0)))};
 state.projects.push(project);
 save(); closeModal(); renderAll(); toast('Proyecto creado');
}
function saveTask(){
 ensureStateShape();
 if(!state.projects.length){toast('Primero crea un proyecto');return}
 const title=val('mTitle');
 if(!title){toast('Ponle título a la tarea');return}
 state.tasks.push({id:uid(),title,desc:val('mDesc'),project:val('mProject',currentProjectId||state.projects[0]?.id||''),status:val('mStatus','pendiente'),priority:val('mPriority','media'),owner:val('mOwner','Fabián'),due:val('mDue'),type:val('mType','gestión')});
 save(); closeModal(); renderAll(); toast('Tarea creada');
}
function saveMeeting(){
 ensureStateShape();
 const title=val('mTitle');
 if(!title){toast('Ponle título a la reunión');return}
 state.meetings.push({id:uid(),title,project:val('mProject',currentProjectId||state.projects[0]?.id||''),date:val('mDate'),people:val('mPeople'),topics:val('mTopics'),agreements:val('mAgreements')});
 save(); closeModal(); renderAll(); toast('Reunión guardada');
}
function saveNote(){
 ensureStateShape();
 const text=val('mText');
 if(!text){toast('Escribe la nota antes de guardar');return}
 state.notes.push({id:uid(),kind:val('mKind','idea'),text,project:val('mProject',currentProjectId||state.projects[0]?.id||''),date:new Date().toISOString()});
 save(); closeModal(); renderAll(); toast('Nota guardada');
}
function saveCase(){
 ensureStateShape();
