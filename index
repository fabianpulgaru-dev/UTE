 const p=state.projects;
 state.tasks=[
  {id:uid(),title:'Preparar demo de chatbot para reunión',desc:'Mostrar lógica de alertas, tiempos y derivaciones.',project:p[0].id,status:'pendiente',priority:'alta',owner:'Fabián',due:isoAdd(0),type:'diseño'},
